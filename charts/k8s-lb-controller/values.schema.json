{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "durationString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[0-9]+(?:\\.[0-9]+)?(?:ns|us|ms|s|m|h)(?:[0-9]+(?:\\.[0-9]+)?(?:ns|us|ms|s|m|h))*$"
    },
    "durationOrEmptyString": {
      "type": "string",
      "pattern": "^$|^[0-9]+(?:\\.[0-9]+)?(?:ns|us|ms|s|m|h)(?:[0-9]+(?:\\.[0-9]+)?(?:ns|us|ms|s|m|h))*$"
    },
    "resourceList": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "integer",
          "number"
        ]
      }
    },
    "seccompProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "localhostProfile": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "type"
      ]
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "add": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "drop": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "probeTiming": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "initialDelaySeconds": {
          "type": "integer",
          "minimum": 0
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "initialDelaySeconds",
        "periodSeconds"
      ]
    },
    "imagePullSecret": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name"
      ]
    },
    "envVar": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        },
        "valueFrom": {
          "type": "object"
        }
      },
      "required": [
        "name"
      ]
    },
    "sysctl": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name",
        "value"
      ]
    },
    "toleration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "operator": {
          "type": "string",
          "enum": [
            "Exists",
            "Equal"
          ]
        },
        "value": {
          "type": "string"
        },
        "effect": {
          "type": "string",
          "enum": [
            "NoSchedule",
            "PreferNoSchedule",
            "NoExecute"
          ]
        },
        "tolerationSeconds": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        },
        "tag": {
          "type": "string"
        }
      },
      "required": [
        "repository",
        "pullPolicy",
        "tag"
      ]
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/imagePullSecret"
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "create",
        "annotations",
        "name"
      ]
    },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean"
        }
      },
      "required": [
        "create"
      ]
    },
    "podAnnotations": {
      "$ref": "#/definitions/stringMap"
    },
    "podLabels": {
      "$ref": "#/definitions/stringMap"
    },
    "podSecurityContext": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "fsGroup": {
          "type": "integer",
          "minimum": 0
        },
        "fsGroupChangePolicy": {
          "type": "string"
        },
        "runAsGroup": {
          "type": "integer",
          "minimum": 0
        },
        "runAsNonRoot": {
          "type": "boolean"
        },
        "runAsUser": {
          "type": "integer",
          "minimum": 0
        },
        "seLinuxOptions": {
          "type": "object"
        },
        "seccompProfile": {
          "$ref": "#/definitions/seccompProfile"
        },
        "supplementalGroups": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "sysctls": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/sysctl"
          }
        },
        "windowsOptions": {
          "type": "object"
        }
      }
    },
    "containerSecurityContext": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "allowPrivilegeEscalation": {
          "type": "boolean"
        },
        "capabilities": {
          "$ref": "#/definitions/capabilities"
        },
        "privileged": {
          "type": "boolean"
        },
        "procMount": {
          "type": "string"
        },
        "readOnlyRootFilesystem": {
          "type": "boolean"
        },
        "runAsGroup": {
          "type": "integer",
          "minimum": 0
        },
        "runAsNonRoot": {
          "type": "boolean"
        },
        "runAsUser": {
          "type": "integer",
          "minimum": 0
        },
        "seLinuxOptions": {
          "type": "object"
        },
        "seccompProfile": {
          "$ref": "#/definitions/seccompProfile"
        },
        "windowsOptions": {
          "type": "object"
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limits": {
          "$ref": "#/definitions/resourceList"
        },
        "requests": {
          "$ref": "#/definitions/resourceList"
        }
      }
    },
    "nodeSelector": {
      "$ref": "#/definitions/stringMap"
    },
    "affinity": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "nodeAffinity": {
          "type": "object"
        },
        "podAffinity": {
          "type": "object"
        },
        "podAntiAffinity": {
          "type": "object"
        }
      }
    },
    "priorityClassName": {
      "type": "string"
    },
    "tolerations": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/toleration"
      }
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 1
    },
    "controller": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "providerMode": {
          "type": "string",
          "enum": [
            "local-haproxy",
            "dataplane-api"
          ]
        },
        "leaderElection": {
          "type": "boolean"
        },
        "loadBalancerClass": {
          "type": "string",
          "minLength": 1
        },
        "ipPool": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "format": "ipv4"
          }
        },
        "requeueAfter": {
          "$ref": "#/definitions/durationString"
        },
        "gracefulShutdownTimeout": {
          "$ref": "#/definitions/durationString"
        },
        "logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        "dataplane": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "apiURL": {
              "type": "string"
            },
            "apiTimeout": {
              "$ref": "#/definitions/durationString"
            }
          },
          "required": [
            "apiURL",
            "apiTimeout"
          ]
        },
        "haproxy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "configPath": {
              "type": "string",
              "minLength": 1
            },
            "validateCommand": {
              "type": "string"
            },
            "reloadCommand": {
              "type": "string"
            }
          },
          "required": [
            "configPath",
            "validateCommand",
            "reloadCommand"
          ]
        }
      },
      "required": [
        "providerMode",
        "leaderElection",
        "loadBalancerClass",
        "ipPool",
        "requeueAfter",
        "gracefulShutdownTimeout",
        "logLevel",
        "dataplane",
        "haproxy"
      ]
    },
    "dataplane": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "hostNetwork": {
          "type": "boolean"
        },
        "shareProcessNamespace": {
          "type": "boolean"
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "pullPolicy": {
              "type": "string",
              "enum": [
                "Always",
                "IfNotPresent",
                "Never"
              ]
            },
            "tag": {
              "type": "string"
            }
          },
          "required": [
            "repository",
            "pullPolicy",
            "tag"
          ]
        },
        "podSecurityContext": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "fsGroup": {
              "type": "integer",
              "minimum": 0
            },
            "fsGroupChangePolicy": {
              "type": "string"
            },
            "runAsGroup": {
              "type": "integer",
              "minimum": 0
            },
            "runAsNonRoot": {
              "type": "boolean"
            },
            "runAsUser": {
              "type": "integer",
              "minimum": 0
            },
            "seLinuxOptions": {
              "type": "object"
            },
            "seccompProfile": {
              "$ref": "#/definitions/seccompProfile"
            },
            "supplementalGroups": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0
              }
            },
            "sysctls": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/sysctl"
              }
            },
            "windowsOptions": {
              "type": "object"
            }
          }
        },
        "containerSecurityContext": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowPrivilegeEscalation": {
              "type": "boolean"
            },
            "capabilities": {
              "$ref": "#/definitions/capabilities"
            },
            "privileged": {
              "type": "boolean"
            },
            "procMount": {
              "type": "string"
            },
            "readOnlyRootFilesystem": {
              "type": "boolean"
            },
            "runAsGroup": {
              "type": "integer",
              "minimum": 0
            },
            "runAsNonRoot": {
              "type": "boolean"
            },
            "runAsUser": {
              "type": "integer",
              "minimum": 0
            },
            "seLinuxOptions": {
              "type": "object"
            },
            "seccompProfile": {
              "$ref": "#/definitions/seccompProfile"
            },
            "windowsOptions": {
              "type": "object"
            }
          }
        },
        "http": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "addr": {
              "type": "string"
            }
          },
          "required": [
            "port",
            "addr"
          ]
        },
        "interface": {
          "type": "string"
        },
        "ipAttach": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "command": {
              "type": "string",
              "minLength": 1
            },
            "cidrSuffix": {
              "type": "integer",
              "minimum": 1,
              "maximum": 32
            }
          },
          "required": [
            "enabled",
            "command",
            "cidrSuffix"
          ]
        },
        "haproxy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "image": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "repository": {
                  "type": "string",
                  "minLength": 1
                },
                "pullPolicy": {
                  "type": "string",
                  "enum": [
                    "Always",
                    "IfNotPresent",
                    "Never"
                  ]
                },
                "tag": {
                  "type": "string"
                }
              },
              "required": [
                "repository",
                "pullPolicy",
                "tag"
              ]
            },
            "configPath": {
              "type": "string",
              "minLength": 1
            },
            "pidFile": {
              "type": "string",
              "minLength": 1
            },
            "validateCommand": {
              "type": "string"
            },
            "reloadCommand": {
              "type": "string"
            },
            "securityContext": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "allowPrivilegeEscalation": {
                  "type": "boolean"
                },
                "capabilities": {
                  "$ref": "#/definitions/capabilities"
                },
                "privileged": {
                  "type": "boolean"
                },
                "procMount": {
                  "type": "string"
                },
                "readOnlyRootFilesystem": {
                  "type": "boolean"
                },
                "runAsGroup": {
                  "type": "integer",
                  "minimum": 0
                },
                "runAsNonRoot": {
                  "type": "boolean"
                },
                "runAsUser": {
                  "type": "integer",
                  "minimum": 0
                },
                "seLinuxOptions": {
                  "type": "object"
                },
                "seccompProfile": {
                  "$ref": "#/definitions/seccompProfile"
                },
                "windowsOptions": {
                  "type": "object"
                }
              }
            },
            "resources": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "limits": {
                  "$ref": "#/definitions/resourceList"
                },
                "requests": {
                  "$ref": "#/definitions/resourceList"
                }
              }
            }
          },
          "required": [
            "image",
            "configPath",
            "pidFile",
            "validateCommand",
            "reloadCommand",
            "securityContext",
            "resources"
          ]
        },
        "logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        "gracefulShutdownTimeout": {
          "$ref": "#/definitions/durationString"
        },
        "terminationGracePeriodSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "limits": {
              "$ref": "#/definitions/resourceList"
            },
            "requests": {
              "$ref": "#/definitions/resourceList"
            }
          }
        },
        "nodeSelector": {
          "$ref": "#/definitions/stringMap"
        },
        "tolerations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/toleration"
          }
        },
        "affinity": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "nodeAffinity": {
              "type": "object"
            },
            "podAffinity": {
              "type": "object"
            },
            "podAntiAffinity": {
              "type": "object"
            }
          }
        }
      },
      "required": [
        "enabled",
        "replicaCount",
        "hostNetwork",
        "shareProcessNamespace",
        "image",
        "podSecurityContext",
        "containerSecurityContext",
        "http",
        "interface",
        "ipAttach",
        "haproxy",
        "logLevel",
        "gracefulShutdownTimeout",
        "terminationGracePeriodSeconds",
        "resources",
        "nodeSelector",
        "tolerations",
        "affinity"
      ]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "annotations": {
              "$ref": "#/definitions/stringMap"
            },
            "labels": {
              "$ref": "#/definitions/stringMap"
            }
          },
          "required": [
            "enabled",
            "annotations",
            "labels"
          ]
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "namespace": {
              "type": "string"
            },
            "annotations": {
              "$ref": "#/definitions/stringMap"
            },
            "labels": {
              "$ref": "#/definitions/stringMap"
            },
            "interval": {
              "$ref": "#/definitions/durationOrEmptyString"
            },
            "scrapeTimeout": {
              "$ref": "#/definitions/durationOrEmptyString"
            },
            "path": {
              "type": "string",
              "pattern": "^/.*"
            },
            "scheme": {
              "type": "string",
              "enum": [
                "http",
                "https"
              ]
            }
          },
          "required": [
            "enabled",
            "namespace",
            "annotations",
            "labels",
            "interval",
            "scrapeTimeout",
            "path",
            "scheme"
          ]
        }
