    "health": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "livenessProbe": {
          "$ref": "#/definitions/probeTiming"
        },
        "readinessProbe": {
          "$ref": "#/definitions/probeTiming"
        }
      },
      "required": [
